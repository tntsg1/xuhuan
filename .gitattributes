# Normalize EOL for all files that Git considers text files.
* text=auto eol=lf

# UE5 LFS rules (TIWAN)
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text
*.ubulk filter=lfs diff=lfs merge=lfs -text
*.uexp filter=lfs diff=lfs merge=lfs -text
*.udic filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.wav filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.ogg filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.fbx filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.glb filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.gltf filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.png filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.jpg filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.tga filter=lfs diff=lfs merge=lfs -text
TIWAN/**/*.psd filter=lfs diff=lfs merge=lfs -text
