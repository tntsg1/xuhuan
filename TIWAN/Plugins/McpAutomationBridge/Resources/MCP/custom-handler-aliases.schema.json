{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unreal-mcp.local/schemas/custom-handler-aliases.schema.json",
  "title": "McpAutomationBridge Custom Handler Aliases",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "aliases": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias", "target"],
        "properties": {
          "alias": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,95}$"
          },
          "target": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,95}$"
          }
        }
      }
    }
  },
  "required": ["version", "aliases"]
}
